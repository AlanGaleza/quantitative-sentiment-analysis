{
  "name": "quantitative-sentiment-analysis-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "lint": "node ./node_modules/eslint/bin/eslint.js \"src/**/*.{ts,tsx}\" eslint.config.js vite.config.ts",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "build": "npm run typecheck && node ./node_modules/vite/bin/vite.js build",
    "test": "node ./node_modules/vitest/vitest.mjs run"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
